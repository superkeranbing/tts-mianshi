# ============================================================
# 听记面试 (TTS-Mianshi) — 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env：
#      cp .env.example .env          (Linux/macOS)
#      copy .env.example .env        (Windows)
#
#   2. 根据你的环境修改以下变量，特别是标记了 <必改> 的项。
#
#   3. 不要将 .env 提交到 Git（已在 .gitignore 中忽略）。
# ============================================================

# === 数据库 =================================================
# PostgreSQL 连接串（异步引擎 asyncpg）
DATABASE_URL=postgresql://dev:dev123@localhost:5432/tts_mianshi
# 同步引擎连接串（Celery / Alembic 使用）
SYNC_DATABASE_URL=postgresql://dev:dev123@localhost:5432/tts_mianshi

# === Redis ==================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === 文件存储后端 ============================================
# 存储后端：local（本地文件系统，开发默认）| minio（MinIO 对象存储，生产推荐）
STORAGE_BACKEND=local

# === MinIO 对象存储 ==========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tts-mianshi

# === ASR 语音识别 ============================================
# 引擎类型：funasr | whisper
ASR_BACKEND=funasr
# 模型存放目录（Docker 中映射到 /app/models/funasr）
ASR_MODEL_DIR=./models/funasr

# === LLM 大语言模型 <必改> ===================================
# DeepSeek / Qwen / OpenAI 兼容 API
LLM_BASE_URL=https://api.deepseek.com/v1
# 替换为你自己的 API Key
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096

# === JWT 认证 <必改> =========================================
# 生产环境务必使用随机字符串：openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
# Token 有效期（分钟），默认 1440 = 24 小时
JWT_EXPIRE_MINUTES=1440

# === 应用 ====================================================
# 调试模式：开发时设为 true，生产环境设为 false
DEBUG=true
# CORS 允许的来源（逗号分隔），生产环境改为你的域名
CORS_ORIGINS=http://localhost:5173,http://localhost:1420,http://localhost:8000
